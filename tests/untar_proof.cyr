# untar_proof.cyr — standalone Linux (NATIVE_FILE) driver: format a sovereign ext2 image, then
# populate its root by EXTRACTING a ustar tarball (df_ext2_untar) — regular files, nested dirs,
# and symlinks. e2fsck / debugfs then validate the extracted tree. Driven by scripts/untar-smoke.sh.
#
# Build: cyrius build tests/untar_proof.cyr build/untar_proof
# Run:   ./build/untar_proof   (formats /tmp/agnova-untar.img + untars /tmp/agnova-rootfs.tar)
#
# SPDX-License-Identifier: GPL-3.0-only

include "src/diskfmt.cyr"

fn main() {
    var path = "/tmp/agnova-untar.img";
    if (df_open_target(path) != 0) { return 1; }
    df_set_geometry(0, 0);
    if (df_format_ext2(0, 524288) != 0) { df_close_target(); return 2; }   # 256 MiB (2 groups)

    var tfd = df_open_src("/tmp/agnova-rootfs.tar");
    if (tfd < 0) { df_close_target(); return 3; }
    var n = df_ext2_untar(tfd);
    df_close_src(tfd);
    if (n < 0) { df_close_target(); return 4; }

    df_close_target();
    return 0;
}

fn _entry() {
    var r = main();
    syscall(SYS_EXIT, r);
    return 0;
}
_entry();
