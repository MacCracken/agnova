# ============================================================
# InstallPhase tests
# ============================================================
fn t_install_phase_ordering() {
    test_group("install_phase_ordering");
    assert(PHASE_VALIDATE_CONFIG < PHASE_PARTITION_DISK, "validate < partition");
    assert(PHASE_INSTALL_BASE < PHASE_INSTALL_PACKAGES, "base < packages");
    assert(PHASE_CLEANUP < PHASE_COMPLETE, "cleanup < complete");
    assert_eq(PHASE_COMPLETE, PHASE_COUNT - 1, "complete == count-1");
    return 0;
}

fn t_install_phase_display() {
    test_group("install_phase_display");
    assert(streq(phase_str(PHASE_VALIDATE_CONFIG), "Validating configuration"), "validate");
    assert(streq(phase_str(PHASE_COMPLETE), "Installation complete"), "complete");
    return 0;
}

fn t_install_phase_next() {
    test_group("install_phase_next");
    assert_eq(phase_next(PHASE_VALIDATE_CONFIG), PHASE_PARTITION_DISK, "validate.next == partition");
    assert_eq(phase_next(PHASE_COMPLETE), 0 - 1, "complete.next == -1");
    return 0;
}

fn t_phase_ordering_encryption_before_format() {
    test_group("phase_ordering_encryption_before_format");
    assert(PHASE_SETUP_ENCRYPTION < PHASE_FORMAT_FILESYSTEMS,
    "SetupEncryption must come before FormatFilesystems");
    return 0;
}

# ============================================================
# DiskLayout tests
# ============================================================
fn t_default_disk_layout_structure() {
    test_group("default_disk_layout_structure");
    var l = agnova_default_disk_layout(str_from("/dev/sda"), 0);
    assert(str_eq_cstr(DiskLayout_target_device(l), "/dev/sda"), "device");
    assert_eq(DiskLayout_use_gpt(l), 1, "use_gpt");
    assert_eq(DiskLayout_encrypt(l), 0, "encrypt off");
    var parts = DiskLayout_partitions(l);
    assert_eq(vec_len(parts), 2, "2 partitions");
    var p0 = vec_get(parts, 0);
    var p1 = vec_get(parts, 1);
    assert(str_eq_cstr(PartitionSpec_label(p0), "ESP"), "ESP label");
    assert_eq(PartitionSpec_size_mb(p0), 512, "ESP 512MB");
    assert_eq(PartitionSpec_has_size(p0), 1, "ESP has size");
    assert(str_eq_cstr(PartitionSpec_mount_point(p1), "/"), "p1 mount=/");
    assert_eq(PartitionSpec_has_size(p1), 0, "p1 fill remaining");
    return 0;
}

fn t_default_disk_layout_with_encryption() {
    test_group("default_disk_layout_with_encryption");
    var l = agnova_default_disk_layout(str_from("/dev/nvme0n1"), 1);
    assert_eq(DiskLayout_encrypt(l), 1, "encrypted");
    assert(str_eq_cstr(DiskLayout_target_device(l), "/dev/nvme0n1"), "nvme device");
    return 0;
}

fn t_disk_layout_gpt_default() {
    test_group("disk_layout_gpt_default");
    var l = disk_layout_default();
    assert_eq(DiskLayout_use_gpt(l), 1, "use_gpt default true");
    return 0;
}

