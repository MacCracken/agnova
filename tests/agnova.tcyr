fn t_system_op_descriptors() {
    # Verify we can construct + read all 6 variant kinds, AND that
    # system_op_display() reproduces the rust-old Display strings
    # (rust-old/src/tests.rs:1240-1263 + the remaining variant forms).
    test_group("system_op_descriptors");
    var args = vec_new();
    vec_push(args, str_from("-s"));
    vec_push(args, str_from("/dev/sda"));
    var c = op_command(str_from("parted"), args, str_from("partition disk"), 1, str_from(""));
    assert_eq(tag(c), OP_COMMAND, "Command tag");
    assert(str_eq_cstr(SystemOp_Command_binary(payload(c)), "parted"), "binary");
    assert(str_eq_cstr(SystemOp_Command_description(payload(c)), "partition disk"), "desc");
    # Display: "{description}: {binary} {args joined by ' '}"
    assert(str_eq_cstr(system_op_display(c), "partition disk: parted -s /dev/sda"), "display command");

    var w = op_write_file(str_from("/etc/hostname"), str_from("agnos\n"), 420, str_from(""));
    assert_eq(tag(w), OP_WRITE_FILE, "WriteFile tag");
    assert(str_eq_cstr(SystemOp_WriteFile_path(payload(w)), "/etc/hostname"), "wf path");
    assert(str_eq_cstr(system_op_display(w), "write /etc/hostname"), "display write");

    var s = op_symlink(str_from("/usr/share/zoneinfo/UTC"), str_from("/etc/localtime"));
    assert_eq(tag(s), OP_SYMLINK, "Symlink tag");
    assert(str_eq_cstr(SystemOp_Symlink_link(payload(s)), "/etc/localtime"), "sl link");
    assert(str_eq_cstr(system_op_display(s), "symlink /etc/localtime -> /usr/share/zoneinfo/UTC"), "display symlink");

    var u = op_unmount(str_from("/mnt"));
    assert_eq(tag(u), OP_UNMOUNT, "Unmount tag");
    assert(str_eq_cstr(system_op_display(u), "umount /mnt"), "display umount");

    var md = op_make_dir(str_from("/mnt/etc"), 493, 1);
    assert_eq(tag(md), OP_MAKE_DIR, "MakeDir tag");
    assert_eq(SystemOp_MakeDir_parents(payload(md)), 1, "parents");
    assert(str_eq_cstr(system_op_display(md), "mkdir /mnt/etc"), "display mkdir");

    var opts = vec_new();
    vec_push(opts, str_from("defaults"));
    var mn = op_mount(str_from("/dev/sda1"), str_from("/mnt"), str_from("ext4"), opts);
    assert_eq(tag(mn), OP_MOUNT, "Mount tag");
    assert(str_eq_cstr(system_op_display(mn), "mount /dev/sda1 on /mnt"), "display mount");
    return 0;
}

# ------------------------------------------------------------
# Additional validation coverage — security-relevant checks that
# the original port left untested (dev-prefix/suffix allowlists,
# kernel-param dangerous-char path, hostname/username bounds,
# no-root-partition, and the two non-fatal warning categories).
# ------------------------------------------------------------

# Build a Str of `n` lowercase 'a' bytes (for length-bound checks).
fn _lower_repeat(n) {
    var sb = str_builder_new();
    var i = 0;
    while (i < n) {
        str_builder_add_byte(sb, 97);
        i = i + 1;
    }
    return str_builder_build(sb);
}

fn t_validate_rejects_device_without_dev_prefix() {
    test_group("validate_rejects_device_without_dev_prefix");
    var c = _test_config();
    DiskLayout_set_target_device(InstallConfig_disk(c), str_from("sda"));
    var r = validate_config(c);
    assert(is_err_result(r), "rejects missing /dev/ prefix");
    assert(str_contains_cstr(payload(r), "/dev/"), "msg mentions /dev/");
    return 0;
}

fn t_validate_rejects_device_suffix_bad_char() {
    test_group("validate_rejects_device_suffix_bad_char");
    var c = _test_config();
    # '#' is not a shell-dangerous char, so it passes check 3 and trips
    # the suffix allowlist (check 4) specifically.
    DiskLayout_set_target_device(InstallConfig_disk(c), str_from("/dev/sda#"));
    var r = validate_config(c);
    assert(is_err_result(r), "rejects bad suffix char");
    assert(str_contains_cstr(payload(r), "after /dev/"), "msg mentions suffix");
    return 0;
}

