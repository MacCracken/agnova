fn t_partition_flag_variants() {
    test_group("partition_flag_variants");
    # 4 distinct values
    assert_neq(PFLAG_BOOT, PFLAG_ESP, "boot != esp");
    assert_neq(PFLAG_BOOT, PFLAG_LVM, "boot != lvm");
    assert_neq(PFLAG_BOOT, PFLAG_RAID, "boot != raid");
    assert_neq(PFLAG_ESP, PFLAG_LVM, "esp != lvm");
    return 0;
}

