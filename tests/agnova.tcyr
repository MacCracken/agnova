# ------------------------------------------------------------
# Additional planner-branch coverage — filesystem variants, MBR,
# swap/encrypted mount paths, the IMA branch, non-Desktop first-boot
# service lists, UUID v4 bit-stamping, and fstab column structure.
# ------------------------------------------------------------

# Build a PartitionSpec with no fixed size and no flags (size irrelevant
# for format/mount planning).
fn _mkpart(label_cstr, mount_cstr, fs) {
    return partition_spec_new(
    str_from(label_cstr), str_from(mount_cstr), fs, 0, 0, vec_new());
}

# Replace a config's disk partition list (keeps the default device/flags).
fn _set_parts(c, parts) {
    DiskLayout_set_partitions(InstallConfig_disk(c), parts);
    return 0;
}

fn t_format_ops_btrfs_xfs_swap() {
    test_group("format_ops_btrfs_xfs_swap");
    var c = _test_config();
    var parts = vec_new();
    vec_push(parts, _mkpart("agnos-root", "/", FS_BTRFS));
    vec_push(parts, _mkpart("home", "/home", FS_XFS));
    vec_push(parts, _mkpart("swap", "none", FS_SWAP));
    _set_parts(c, parts);
    var ops = PhaseOps_operations(plan_format_ops(c));
    assert(_ops_has_command_binary(ops, "mkfs.btrfs"), "btrfs mkfs");
    assert(_ops_has_command_arg(ops, "-f"), "btrfs -f flag");
    assert(_ops_has_command_binary(ops, "mkfs.xfs"), "xfs mkfs");
    assert(_ops_has_command_binary(ops, "mkswap"), "swap mkswap");
    return 0;
}

