fn t_plan_network_ops_static_ip_config() {
    test_group("plan_network_ops_static_ip_config");
    var c = _test_config();
    var net = InstallConfig_network(c);
    NetworkConfig_set_use_dhcp(net, 0);
    NetworkConfig_set_static_ip(net, str_from("192.168.1.100/24"));
    NetworkConfig_set_gateway(net, str_from("192.168.1.1"));
    var dns = vec_new();
    vec_push(dns, str_from("1.1.1.1"));
    vec_push(dns, str_from("8.8.8.8"));
    NetworkConfig_set_dns(net, dns);
    var ops = PhaseOps_operations(plan_network_ops(c, str_from("/mnt/target")));
    var w = _find_write(ops, "10-static.network");
    assert(w != 0, "10-static.network exists");
    var content = SystemOp_WriteFile_content(w);
    assert(str_contains_cstr(content, "[Match]"), "[Match]");
    assert(str_contains_cstr(content, "Name=eth0"), "Name=eth0");
    assert(str_contains_cstr(content, "Address=192.168.1.100/24"), "Address");
    assert(str_contains_cstr(content, "Gateway=192.168.1.1"), "Gateway");
    assert(str_contains_cstr(content, "DNS=1.1.1.1"), "DNS=1.1.1.1");
    assert(str_contains_cstr(content, "DNS=8.8.8.8"), "DNS=8.8.8.8");
    return 0;
}

