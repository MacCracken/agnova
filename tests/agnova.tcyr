fn t_validate_rejects_fill_remaining_not_last() {
    test_group("validate_rejects_fill_remaining_not_last");
    var c = _test_config();
    # First partition: clear has_size so it claims fill-remaining
    var p0 = vec_get(DiskLayout_partitions(InstallConfig_disk(c)), 0);
    PartitionSpec_set_has_size(p0, 0);
    PartitionSpec_set_size_mb(p0, 0);
    # Add a third partition so first is no longer last
    var extra = partition_spec_new(
    str_from("extra"), str_from("/data"), FS_EXT4, 1024, 1, vec_new());
    vec_push(DiskLayout_partitions(InstallConfig_disk(c)), extra);
    var r = validate_config(c);
    assert(is_err_result(r), "rejects fill-remaining-not-last");
    assert(str_contains_cstr(payload(r), "non-last"), "msg mentions non-last");
    return 0;
}

