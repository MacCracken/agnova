fn t_luks_format_uses_stdin_passphrase() {
    test_group("luks_format_uses_stdin_passphrase");
    var c = _test_config();
    DiskLayout_set_encrypt(InstallConfig_disk(c), 1);
    var phase = plan_encryption_ops(c, str_from("hunter2"));
    var ops = PhaseOps_operations(phase);
    assert(vec_len(ops) >= 2, "at least 2 ops");
    var fmt = vec_get(ops, 0);
    assert(str_eq_cstr(SystemOp_Command_binary(payload(fmt)), "cryptsetup"), "fmt cryptsetup");
    var args0 = SystemOp_Command_args(payload(fmt));
    assert(_vec_str_any_eq(args0, "--batch-mode"), "--batch-mode");
    assert(_vec_str_any_eq(args0, "--key-file=-"), "--key-file=-");
    assert(str_eq_cstr(SystemOp_Command_stdin(payload(fmt)), "hunter2"), "stdin = passphrase");
    var open_op = vec_get(ops, 1);
    var args1 = SystemOp_Command_args(payload(open_op));
    assert(_vec_str_any_eq(args1, "open"), "open");
    assert(_vec_str_any_eq(args1, "--key-file=-"), "open --key-file=-");
    assert(str_eq_cstr(SystemOp_Command_stdin(payload(open_op)), "hunter2"), "open stdin");
    return 0;
}

# ============================================================
# Bootloader ops tests
# ============================================================
fn t_bootloader_ops_grub() {
    test_group("bootloader_ops_grub");
    var c = _test_config();
    BootloaderConfig_set_bootloader_type(InstallConfig_bootloader(c), BOOT_GRUB2);
    var phase = plan_bootloader_ops(c, str_from("/mnt"));
    assert_eq(PhaseOps_phase(phase), PHASE_INSTALL_BOOTLOADER, "phase tag");
    var ops = PhaseOps_operations(phase);
    assert_eq(vec_len(ops), 3, "3 ops (grub-install + mkdir + cfg)");
    assert(str_eq_cstr(SystemOp_Command_binary(payload(vec_get(ops, 0))), "grub-install"),
    "first is grub-install");
    var cfg_op = vec_get(ops, 2);
    assert_eq(tag(cfg_op), OP_WRITE_FILE, "third is WriteFile");
    assert(str_contains_cstr(SystemOp_WriteFile_path(payload(cfg_op)), "grub.cfg"), "path grub.cfg");
    assert(str_contains_cstr(SystemOp_WriteFile_content(payload(cfg_op)), "AGNOS"), "content AGNOS");
    assert(str_contains_cstr(SystemOp_WriteFile_content(payload(cfg_op)), "rescue"), "rescue entry");
    return 0;
}

