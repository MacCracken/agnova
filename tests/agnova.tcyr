fn t_generate_fstab_basic() {
    test_group("generate_fstab_basic");
    var parts = vec_new();
    vec_push(parts, partition_spec_new(
    str_from("ESP"), str_from("/boot/efi"), FS_VFAT, 512, 1,
    vec_new()));
    vec_push(parts, partition_spec_new(
    str_from("agnos-root"), str_from("/"), FS_EXT4, 0, 0, vec_new()));
    var fstab = generate_fstab(parts, 0);
    assert(str_contains_cstr(fstab, "LABEL=ESP"), "has LABEL=ESP");
    assert(str_contains_cstr(fstab, "LABEL=agnos-root"), "has LABEL=agnos-root");
    assert(str_contains_cstr(fstab, "vfat"), "has vfat");
    assert(str_contains_cstr(fstab, "ext4"), "has ext4");
    return 0;
}

