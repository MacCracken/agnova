    test_group("encryption_ops_empty_partitions_no_panic");
    var c = _test_config();
    DiskLayout_set_encrypt(InstallConfig_disk(c), 1);
    DiskLayout_set_partitions(InstallConfig_disk(c), vec_new());
    var phase = plan_encryption_ops(c, str_from("hunter2"));
    assert_eq(vec_len(PhaseOps_operations(phase)), 0, "no ops, no panic");
