fn t_encryption_ops_luks_when_enabled() {
    test_group("encryption_ops_luks_when_enabled");
    var c = _test_config();
    DiskLayout_set_encrypt(InstallConfig_disk(c), 1);
    var phase = plan_encryption_ops(c, str_from("hunter2"));
    var ops = PhaseOps_operations(phase);
    assert_eq(vec_len(ops), 2, "2 cryptsetup ops");
    var op0 = vec_get(ops, 0);
    var op1 = vec_get(ops, 1);
    assert(str_eq_cstr(SystemOp_Command_binary(payload(op0)), "cryptsetup"), "cryptsetup");
    assert(_vec_str_any_eq(SystemOp_Command_args(payload(op0)), "luksFormat"), "luksFormat");
    assert(str_eq_cstr(SystemOp_Command_binary(payload(op1)), "cryptsetup"), "cryptsetup");
    assert(_vec_str_any_eq(SystemOp_Command_args(payload(op1)), "open"), "open");
    return 0;
}

