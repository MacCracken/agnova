    test_group("bootloader_ops_systemd_boot");
    var c = _test_config();
    BootloaderConfig_set_bootloader_type(InstallConfig_bootloader(c), BOOT_SYSTEMD);
    var ops = PhaseOps_operations(plan_bootloader_ops(c, str_from("/mnt")));
    assert(str_eq_cstr(SystemOp_Command_binary(payload(vec_get(ops, 0))), "bootctl"), "bootctl");
    return 0;
}

fn t_bootloader_default_is_gnoboot() {
    test_group("bootloader_default_is_gnoboot");
    var b = bootloader_config_default();
    assert_eq(BootloaderConfig_bootloader_type(b), BOOT_GNOBOOT, "default bootloader = gnoboot");
    return 0;
}

fn t_bootloader_ops_gnoboot() {
    test_group("bootloader_ops_gnoboot");
    var c = _test_config();
    BootloaderConfig_set_bootloader_type(InstallConfig_bootloader(c), BOOT_GNOBOOT);
    var ops = PhaseOps_operations(plan_bootloader_ops(c, str_from("/mnt")));
    # 2 ESP mkdirs + cp gnoboot -> BOOTX64.EFI + cp kernel -> /boot/agnos; no GRUB/bootctl.
    assert(vec_len(ops) >= 4, "gnoboot: >=4 ESP-staging ops");
    assert_eq(tag(vec_get(ops, 2)), OP_COMMAND, "gnoboot: op2 is Command");
    assert(str_eq_cstr(SystemOp_Command_binary(payload(vec_get(ops, 2))), "cp"), "gnoboot: stages EFI via cp");
    return 0;
}

fn t_bootloader_grub_bios_mode() {
    test_group("bootloader_grub_bios_mode");
    var c = _test_config();
    BootloaderConfig_set_bootloader_type(InstallConfig_bootloader(c), BOOT_GRUB2);
    var ops = PhaseOps_operations(plan_bootloader_ops(c, str_from("/mnt")));
    var op0 = vec_get(ops, 0);
    assert_eq(tag(op0), OP_COMMAND, "Command");
    var args = SystemOp_Command_args(payload(op0));
    var has_target = 0;
    var n = vec_len(args);
    var i = 0;
    while (i < n) {
        if (str_starts_with(vec_get(args, i), str_from("--target=")) == 1) { has_target = 1; }
        i = i + 1;
    }
    assert(has_target, "has --target= arg");
    return 0;
}

fn t_bootloader_systemd_boot_has_entry_files() {
    test_group("bootloader_systemd_boot_has_entry_files");
    var c = _test_config();
    BootloaderConfig_set_bootloader_type(InstallConfig_bootloader(c), BOOT_SYSTEMD);
    var ops = PhaseOps_operations(plan_bootloader_ops(c, str_from("/mnt")));
    assert(_ops_has_write_path(ops, "loader.conf"), "loader.conf");
    assert(_ops_has_write_path(ops, "agnos.conf"), "agnos.conf");
    assert(_ops_has_write_path(ops, "agnos-rescue.conf"), "rescue entry");
    return 0;
}

fn t_grub_cfg_uses_kernel_version() {
    test_group("grub_cfg_uses_kernel_version");
    var c = _test_config();
    BootloaderConfig_set_bootloader_type(InstallConfig_bootloader(c), BOOT_GRUB2);
    var ops = PhaseOps_operations(plan_bootloader_ops(c, str_from("/mnt")));
    var w = _find_write(ops, "grub.cfg");
    assert(w != 0, "grub.cfg exists");
    var content = SystemOp_WriteFile_content(w);
    assert(str_contains_cstr(content, "vmlinuz-"), "references kernel by version");
    assert(str_contains_cstr(content, "initramfs-"), "references initramfs");
    var kver = kernel_version();
    var kver_data = str_data(kver);
    var kver_len = str_len(kver);
    # Build a cstr from kver and check via str_contains
    var kver_cstr = str_cstr(kver);
    assert(str_contains_cstr(content, kver_cstr), "references kernel_version()");
    return 0;
}

