fn t_install_mode_display() {
    test_group("install_mode_display");
    assert(streq(mode_str(MODE_SERVER), "Server"), "Server");
    assert(streq(mode_str(MODE_DESKTOP), "Desktop"), "Desktop");
    assert(streq(mode_str(MODE_MINIMAL), "Minimal"), "Minimal");
    assert(streq(mode_str(MODE_CUSTOM), "Custom"), "Custom");
    return 0;
}

fn t_filesystem_display() {
    test_group("filesystem_display");
    assert(streq(fs_str(FS_EXT4), "ext4"), "ext4");
    assert(streq(fs_str(FS_BTRFS), "btrfs"), "btrfs");
    assert(streq(fs_str(FS_XFS), "xfs"), "xfs");
    assert(streq(fs_str(FS_VFAT), "vfat"), "vfat");
    assert(streq(fs_str(FS_SWAP), "swap"), "swap");
