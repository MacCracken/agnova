# PackageSelection tests
# ============================================================
fn t_default_packages_server() {
    test_group("default_packages_server");
    var p = default_packages(MODE_SERVER);
    assert(vec_len(PackageSelection_base_packages(p)) > 0, "base nonempty");
    assert(vec_len(PackageSelection_mode_packages(p)) > 0, "mode nonempty");
    assert(_vec_str_any_eq(PackageSelection_base_packages(p), "agnos-kernel"), "has kernel");
    assert(_vec_str_any_eq(PackageSelection_mode_packages(p), "ark"), "server mode has ark");
    return 0;
}

fn t_default_packages_desktop_more_than_server() {
    test_group("default_packages_desktop_more_than_server");
    var d = default_packages(MODE_DESKTOP);
    var s = default_packages(MODE_SERVER);
    assert(vec_len(PackageSelection_mode_packages(d)) > vec_len(PackageSelection_mode_packages(s)),
    "desktop > server mode pkgs");
    assert(PackageSelection_total_size_mb(d) > PackageSelection_total_size_mb(s),
    "desktop > server total size");
    return 0;
}

fn t_default_packages_minimal_fewest() {
    test_group("default_packages_minimal_fewest");
    var m = default_packages(MODE_MINIMAL);
    assert_eq(vec_len(PackageSelection_mode_packages(m)), 0, "minimal mode pkgs empty");
    assert(PackageSelection_total_size_mb(m) < 1000, "minimal < 1000MB");
    return 0;
}

fn t_package_selection_total_count() {
    test_group("package_selection_total_count");
    var base = vec_new();
    vec_push(base, str_from("a"));
    vec_push(base, str_from("b"));
    var mode = vec_new();
    vec_push(mode, str_from("c"));
    var extra = vec_new();
    vec_push(extra, str_from("d"));
    vec_push(extra, str_from("e"));
    vec_push(extra, str_from("f"));
    var p = package_selection_new(base, mode, extra, 100);
    assert_eq(package_selection_total_count(p), 6, "2+1+3 = 6");
    return 0;
}

