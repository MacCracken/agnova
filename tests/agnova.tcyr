# tests/agnova.tcyr — agnova test suite
#
# Ported from rust-old/src/tests.rs (104 #[test] functions).
# Run: cyrius test tests/agnova.tcyr
#
# Tests are pure planner assertions: they build configs, call planners,
# and check shape/content of the resulting PhaseOps + SystemOp values.
# NEVER call execute_op or anything that touches disk from here.

include "src/types.cyr"
include "src/diskfmt.cyr"
include "src/disk_backend.cyr"
include "src/helpers.cyr"
include "src/validation.cyr"
include "src/partitioning.cyr"
include "src/rootfs.cyr"
include "src/orchestrator.cyr"
# executor.cyr deliberately NOT included — tests are pure-planner.
# cli.cyr also not included — tests exercise the library directly.

# ============================================================
# Test fixtures + predicate helpers
# ============================================================

# A valid InstallConfig matching the Rust test_config() helper:
# Desktop mode, /dev/sda, default ESP+root, testuser, defaults everywhere.
fn _test_config() {
    var cfg = install_config_default();
    var disk = agnova_default_disk_layout(str_from("/dev/sda"), 0);
    InstallConfig_set_disk(cfg, disk);
    UserConfig_set_username(InstallConfig_user(cfg), str_from("testuser"));
    return cfg;
}

# True if any element of a vec<Str> equals the cstr.
fn _vec_str_any_eq(v, cstr) {
    var n = vec_len(v);
    var i = 0;
    while (i < n) {
        if (str_eq_cstr(vec_get(v, i), cstr) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# True if any element of a vec<Str> contains the cstr substring.
fn _vec_str_any_contains(v, cstr) {
    var n = vec_len(v);
    var i = 0;
    while (i < n) {
        if (str_contains_cstr(vec_get(v, i), cstr) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# True if any op in the vec is a Command with the given binary.
fn _ops_has_command_binary(ops, binary_cstr) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        if (tag(op) == OP_COMMAND) {
            if (str_eq_cstr(SystemOp_Command_binary(payload(op)), binary_cstr) == 1) {
                return 1;
            }
        }
        i = i + 1;
    }
    return 0;
}

# True if any op is a Command whose args contain the given cstr literally.
fn _ops_has_command_arg(ops, needle_cstr) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        if (tag(op) == OP_COMMAND) {
            if (_vec_str_any_eq(SystemOp_Command_args(payload(op)), needle_cstr) == 1) {
                return 1;
            }
        }
        i = i + 1;
    }
    return 0;
}

# True if any op is a WriteFile with path containing the substring.
fn _ops_has_write_path(ops, needle_cstr) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        if (tag(op) == OP_WRITE_FILE) {
            if (str_contains_cstr(SystemOp_WriteFile_path(payload(op)), needle_cstr) == 1) {
                return 1;
            }
        }
        i = i + 1;
    }
    return 0;
}

# True if any op is a WriteFile whose path contains needle1 AND content contains needle2.
fn _ops_has_write_path_content(ops, path_needle, content_needle) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        if (tag(op) == OP_WRITE_FILE) {
            var p = payload(op);
            if (str_contains_cstr(SystemOp_WriteFile_path(p), path_needle) == 1) {
                if (str_contains_cstr(SystemOp_WriteFile_content(p), content_needle) == 1) {
                    return 1;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# True if any op is an Unmount.
fn _ops_has_unmount(ops) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        if (tag(vec_get(ops, i)) == OP_UNMOUNT) { return 1; }
        i = i + 1;
    }
    return 0;
}

# True if any op is a Mount.
fn _ops_has_mount(ops) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        if (tag(vec_get(ops, i)) == OP_MOUNT) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Find the first WriteFile op whose path contains the substring;
# return WriteFile payload ptr or 0 if not found.
fn _find_write(ops, needle_cstr) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        if (tag(op) == OP_WRITE_FILE) {
            if (str_contains_cstr(SystemOp_WriteFile_path(payload(op)), needle_cstr) == 1) {
                return payload(op);
            }
        }
        i = i + 1;
    }
    return 0;
}

# Find the first Mount op; return SystemOp_Mount payload or 0.
fn _find_mount(ops) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        if (tag(op) == OP_MOUNT) { return payload(op); }
        i = i + 1;
    }
    return 0;
}

# Find the first Symlink op; return payload or 0.
fn _find_symlink(ops) {
    var n = vec_len(ops);
    var i = 0;
    while (i < n) {
        var op = vec_get(ops, i);
        if (tag(op) == OP_SYMLINK) { return payload(op); }
        i = i + 1;
    }
    return 0;
}

# True if every byte of Str s is an ASCII hex digit (0-9 a-f A-F).
fn _all_hex(s) {
    var data = str_data(s);
    var n = str_len(s);
    var i = 0;
    while (i < n) {
        var c = load8(data + i);
        var ok = 0;
        if (c >= 48) { if (c <= 57) { ok = 1; } }
        if (c >= 97) { if (c <= 102) { ok = 1; } }
        if (c >= 65) { if (c <= 70) { ok = 1; } }
        if (ok == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}

