fn t_validate_rejects_mbr_with_more_than_four_partitions() {
    test_group("validate_rejects_mbr_with_more_than_four_partitions");
    var c = _test_config();
    var disk = InstallConfig_disk(c);
    DiskLayout_set_use_gpt(disk, 0);
    var parts = vec_new();
    var i = 1;
    while (i <= 5) {
        var label_sb = str_builder_new();
        str_builder_add_cstr(label_sb, "part");
        str_builder_add_int(label_sb, i);
        var mp_sb = str_builder_new();
        if (i == 5) {
            str_builder_add_cstr(mp_sb, "/");
        } else {
            str_builder_add_cstr(mp_sb, "/mnt/");
            str_builder_add_int(mp_sb, i);
        }
        var has_size = 1;
        var size = 1024;
        if (i == 5) { has_size = 0; size = 0; }
        vec_push(parts, partition_spec_new(
        str_builder_build(label_sb), str_builder_build(mp_sb),
        FS_EXT4, size, has_size, vec_new()));
        i = i + 1;
    }
    DiskLayout_set_partitions(disk, parts);
    var r = validate_config(c);
    assert(is_err_result(r), "rejects MBR > 4");
    assert(str_contains_cstr(payload(r), "MBR"), "msg mentions MBR");
    return 0;
}

fn t_validate_accepts_mbr_with_four_partitions() {
    test_group("validate_accepts_mbr_with_four_partitions");
    var c = _test_config();
    var disk = InstallConfig_disk(c);
    DiskLayout_set_use_gpt(disk, 0);
    var parts = vec_new();
    var i = 1;
    while (i <= 4) {
        var label_sb = str_builder_new();
        str_builder_add_cstr(label_sb, "part");
        str_builder_add_int(label_sb, i);
        var mp_sb = str_builder_new();
        if (i == 4) {
            str_builder_add_cstr(mp_sb, "/");
        } else {
            str_builder_add_cstr(mp_sb, "/mnt/");
            str_builder_add_int(mp_sb, i);
        }
        var has_size = 1;
        var size = 1024;
        if (i == 4) { has_size = 0; size = 0; }
        vec_push(parts, partition_spec_new(
        str_builder_build(label_sb), str_builder_build(mp_sb),
        FS_EXT4, size, has_size, vec_new()));
        i = i + 1;
    }
    DiskLayout_set_partitions(disk, parts);
    var r = validate_config(c);
    assert(is_ok(r), "accepts MBR with 4 partitions");
    return 0;
}

# ============================================================
# Phase advancement tests
# ============================================================
fn t_phase_advancement_sequence() {
    test_group("phase_advancement_sequence");
    var inst = agnova_installer_new(_test_config(), str_from(""));
    assert_eq(agnova_current_phase(inst), PHASE_VALIDATE_CONFIG, "starts at validate");
    assert_eq(agnova_advance_phase(inst), 1, "advance ok");
    assert_eq(agnova_current_phase(inst), PHASE_PARTITION_DISK, "now at partition");
    return 0;
}

fn t_phase_advancement_past_complete_returns_false() {
    test_group("phase_advancement_past_complete_returns_false");
    var inst = agnova_installer_new(_test_config(), str_from(""));
    while (agnova_advance_phase(inst) == 1) { }
    assert_eq(agnova_is_complete(inst), 1, "is complete");
    assert_eq(agnova_advance_phase(inst), 0, "past complete returns 0");
    return 0;
}

fn t_fail_phase_records_error() {
    test_group("fail_phase_records_error");
    var inst = agnova_installer_new(_test_config(), str_from(""));
    agnova_fail_phase(inst, str_from("disk I/O error"));
    var errs = AgnovaInstaller_errors(inst);
    assert_eq(vec_len(errs), 1, "1 error");
    var e = vec_get(errs, 0);
    assert_eq(InstallError_phase(e), PHASE_VALIDATE_CONFIG, "phase = validate");
    assert(str_eq_cstr(InstallError_message(e), "disk I/O error"), "message preserved");
    return 0;
}

fn t_advance_phase_blocked_after_non_recoverable_failure() {
    test_group("advance_phase_blocked_after_non_recoverable_failure");
    var inst = agnova_installer_new(_test_config(), str_from(""));
    agnova_advance_phase(inst);
    assert_eq(agnova_current_phase(inst), PHASE_PARTITION_DISK, "at partition");
    agnova_fail_phase(inst, str_from("disk not found"));
    var errs = AgnovaInstaller_errors(inst);
    var last = vec_get(errs, vec_len(errs) - 1);
    assert_eq(InstallError_recoverable(last), 0, "non-recoverable");
    assert_eq(agnova_advance_phase(inst), 0, "blocked");
    assert_eq(agnova_current_phase(inst), PHASE_PARTITION_DISK, "still at partition");
    return 0;
}

# ============================================================
# Result tests
# ============================================================
fn t_result_after_completion() {
    test_group("result_after_completion");
    var inst = agnova_installer_new(_test_config(), str_from(""));
    while (agnova_advance_phase(inst) == 1) { }
    var r = agnova_result(inst);
    assert_eq(InstallResult_success(r), 1, "success");
    assert_eq(vec_len(InstallResult_errors(r)), 0, "no errors");
    assert(vec_len(InstallResult_phases_completed(r)) > 0, "phases completed");
    return 0;
}

fn t_result_with_errors() {
    test_group("result_with_errors");
    var inst = agnova_installer_new(_test_config(), str_from(""));
    agnova_fail_phase(inst, str_from("something broke"));
    var r = agnova_result(inst);
    assert_eq(InstallResult_success(r), 0, "not success");
    assert_eq(vec_len(InstallResult_errors(r)), 1, "1 error");
    return 0;
}

