# ============================================================
# InstallPhase — execution order matches Rust ALL slice
# ============================================================
enum InstallPhase {
    PHASE_VALIDATE_CONFIG = 0;
    PHASE_PARTITION_DISK = 1;
    PHASE_SETUP_ENCRYPTION = 2;
    PHASE_FORMAT_FILESYSTEMS = 3;
    PHASE_MOUNT_FILESYSTEMS = 4;
    PHASE_INSTALL_BASE = 5;
    PHASE_INSTALL_PACKAGES = 6;
    PHASE_CONFIGURE_SYSTEM = 7;
    PHASE_INSTALL_BOOTLOADER = 8;
    PHASE_CREATE_USER = 9;
    PHASE_SETUP_SECURITY = 10;
    PHASE_FIRST_BOOT_SETUP = 11;
    PHASE_CLEANUP = 12;
    PHASE_COMPLETE = 13;
}

var PHASE_COUNT = 14;

fn phase_str(p) {
    if (p == PHASE_VALIDATE_CONFIG) { return "Validating configuration"; }
    if (p == PHASE_PARTITION_DISK) { return "Partitioning disk"; }
    if (p == PHASE_FORMAT_FILESYSTEMS) { return "Formatting filesystems"; }
    if (p == PHASE_SETUP_ENCRYPTION) { return "Setting up encryption"; }
    if (p == PHASE_MOUNT_FILESYSTEMS) { return "Mounting filesystems"; }
    if (p == PHASE_INSTALL_BASE) { return "Installing base system"; }
    if (p == PHASE_INSTALL_PACKAGES) { return "Installing packages"; }
    if (p == PHASE_CONFIGURE_SYSTEM) { return "Configuring system"; }
    if (p == PHASE_INSTALL_BOOTLOADER) { return "Installing bootloader"; }
    if (p == PHASE_CREATE_USER) { return "Creating user account"; }
    if (p == PHASE_SETUP_SECURITY) { return "Setting up security"; }
    if (p == PHASE_FIRST_BOOT_SETUP) { return "Preparing first boot"; }
    if (p == PHASE_CLEANUP) { return "Cleaning up"; }
    if (p == PHASE_COMPLETE) { return "Installation complete"; }
    return "unknown";
}

# Returns next phase index or -1 if already at PHASE_COMPLETE.
fn phase_next(p) {
    if (p >= PHASE_COMPLETE) { return -1; }
    return p + 1;
}

# ============================================================
# SystemOp — tagged union over 6 system action variants
# ============================================================
# Layout: tagged_new(tag, &variant_payload_struct).
# Read with tag(op) + payload(op); cast payload to the matching
# struct pointer and load fields by offset (or via field accessors).
# JSON serialization is manual (#derive(Serialize) does not handle
# discriminated unions).

enum SystemOpTag {
    OP_COMMAND = 0;
    OP_WRITE_FILE = 1;
    OP_MAKE_DIR = 2;
    OP_SYMLINK = 3;
    OP_MOUNT = 4;
    OP_UNMOUNT = 5;
}

# --- Variant: Command ---
# stdin: Str (empty == no stdin); args: vec<Str>
#derive(Serialize)
struct SystemOp_Command {
    binary: Str;
    args;
    description: Str;
    fatal;
    stdin: Str;
}

fn op_command(binary, args, description, fatal, stdin) {
    var p = alloc(sizeof(SystemOp_Command));
    store64(p, binary);
    store64(p + 8, args);
    store64(p + 16, description);
    store64(p + 24, fatal);
    store64(p + 32, stdin);
    return tagged_new(OP_COMMAND, p);
}

# Smoke: confirm we can read back what we wrote.
fn op_command_binary(op) {
    return load64(payload(op));
}
