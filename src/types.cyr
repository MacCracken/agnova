# types.cyr — agnova core types (enums, structs, SystemOp tagged union)
#
# Ported from rust-old/src/types.rs
#
# Conventions:
#   - Enum members are upper-case + prefixed (Cyrius enums are global)
#   - Stringify fns return cstr (C-string literal); use str_from() for Str
#   - Option<T> in Rust → empty Str sentinel for strings, separate has_X flag for ints
#   - f32 progress → i64 basis points (0..10000)
#   - DateTime<Utc> → i64 unix seconds
#   - luks_passphrase is NOT in DiskLayout (held by orchestrator); preserves the
#     #[serde(skip)] semantics from the Rust version

# ============================================================
# InstallMode
# ============================================================
enum InstallMode {
    MODE_SERVER = 0;
    MODE_DESKTOP = 1;
    MODE_MINIMAL = 2;
    MODE_CUSTOM = 3;
}

fn mode_str(m) {
    if (m == MODE_SERVER) { return "Server"; }
    if (m == MODE_DESKTOP) { return "Desktop"; }
    if (m == MODE_MINIMAL) { return "Minimal"; }
    if (m == MODE_CUSTOM) { return "Custom"; }
    return "Unknown";
}

# ============================================================
# Filesystem
# ============================================================
enum Filesystem {
    FS_EXT4 = 0;
    FS_BTRFS = 1;
    FS_XFS = 2;
    FS_VFAT = 3;
    FS_SWAP = 4;
}

fn fs_str(f) {
    if (f == FS_EXT4) { return "ext4"; }
    if (f == FS_BTRFS) { return "btrfs"; }
    if (f == FS_XFS) { return "xfs"; }
    if (f == FS_VFAT) { return "vfat"; }
    if (f == FS_SWAP) { return "swap"; }
    return "unknown";
}

